<style>
  .work ul {
    /* background: aqua; */
    display: flex;
    flex-direction: column;
    gap: var(--space-6);

    li {
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
    }
    article {
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
    }

    .row {
      display: flex;
      gap: var(--space-2);
    }
    span {
      /* background-color: lemonchiffon; */
      display: block;
      flex: 0;
      width: fit-content;
      font-size: 12px;
      font-weight: 500;
      padding: 0.1lh 0.2lh;
      border-radius: 4px;
    }
  }
</style>
