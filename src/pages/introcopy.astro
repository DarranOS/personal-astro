    href: "/work/internal-product",
    tagColor: "dustyblue",
  },
  {
    category: "Three.js",
    title: "Interactive particle study",
    description: "A small WebGL piece exploring instanced geometry and scroll.",
    href: "/work/threejs-particle-study",
    tagColor: "mauve",
  },
  {
    category: "Three.js",
    title: "Interactive particle study",
    description: "A small WebGL piece exploring instanced geometry and scroll.",
    href: "/work/threejs-particle-study",
    tagColor: "rosewood",
  },
];
const selectedList = [
  {
    category: "AI & Delivery",
    title: " What 41% actually means: measuring AI adoption in a real agency",
    description: "Not less work — different work, and a different bottleneck.",
    href: "/work/ai-adoption-rollout",
    tagColor: "clay",
  },
  {
    category: "Process",
    title: "Running 350+ projects a year without losing the thread",
    description:
      "Hospitality operations and software delivery rhyme more than people expect.",
    href: "/work/internal-product",
    tagColor: "mauve",
  },
  {
    category: "Career",
    title: "Interactive particle study",
    description: "A small WebGL piece exploring instanced geometry and scroll.",
    href: "/work/threejs-particle-study",
    tagColor: "sand",
  },
  {
    category: "Three.js",
    title: "Interactive particle study",
    description:
      "Hospitality to code to delivery — what the arc looks like from the inside.",
    href: "/work/threejs-particle-study",
    tagColor: "rosewood",
  },
