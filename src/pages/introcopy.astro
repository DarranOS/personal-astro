  <style>
    .tags ul {
      /* background: aqua; */
      display: flex;
      flex-direction: column;
      gap: var(--space-6);

      li {
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
      }
      article {
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
      }

      .row {
        display: flex;
        gap: var(--space-2);
      }

      .work-preview__item {
        outline: 2px solid var(--color-border);
        padding: 1rem;
        background-color: var(--color-bg-raised);
        border-radius: 2rem;

        & img {
          border-radius: 2rem;
          width: 100%;
          aspect-ratio: 1;
        }
      }
    }
    .work-preview__list {
      display: grid !important;
      gap: 1rem !important;

      /* border: 3px solid lime; */
      /* background-color: rgba(255, 255, 0, 0.152); */

      @container marquee (min-width: 80ch) {
        grid-template-columns: 1fr 1fr !important;
        grid-area: cards;
      }
    }

    .work-preview__meta {
      /* background-color: lime; */
      display: flex;
      flex-direction: column;
      gap: var(--space-1) !important;
    }

    .work-preview__title {
      font-size: 1.4rem !important;
      font-family: var(--font-display);
      font-weight: 400 !important;
    }

    .marquee-grid {
      display: grid !important;
      /* border: 3px solid cyan;
    background-color: rgba(255, 255, 0, 0.152); */
      gap: 2rem;
      grid-template-columns: 1fr;

      @container marquee (min-width: 70ch) {
        grid-template-columns: 2fr 1fr !important;
        grid-template-rows: auto !important;
        /* gap: var(--space-4); */
        grid-template-areas:
          "cards notes"
          "list notes";
      }
    }

    .notepad-notes {
      /* outline: 4px solid red;
    background-color: rgba(255, 0, 187, 0.172); */
      display: flex;
      flex-direction: column;
      gap: 2rem;
      @container marquee (min-width: 70ch) {
        grid-area: notes;
      }
    }
    .listpad-list {
      /* background-color: rgba(0, 255, 13, 0.172); */
      @container marquee (min-width: 70ch) {
        grid-area: list;
      }
    }

    .marquee-container {
      container-type: inline-size;
      container-name: marquee;
    }

    .subsection_text {
      color: var(--color-text) !important;
      font-size: var(--font-size-lg);
    }
  </style>
</section>
