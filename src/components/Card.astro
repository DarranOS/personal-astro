---
export type Props = {
  to: string;
  title: string;
  image: string;
  gradientFrom: string;
  gradientTo: string;
};

const { to, title, gradientFrom, gradientTo } = Astro.props;
---

<a href={to} class="card">
  <img
    transition:name="hero"
    class="card__image"
    src={Astro.props.image}
    alt={title}
  />
  <div class="card__inner">
    <div class="card__title">{title}</div>
    <div class="card__footer">&rarr;</div>
  </div>
  <slot />
</a>

<style define:vars={{ gradientFrom, gradientTo }}>
  .card {
    --radius: 10px;

    transition: scale 0.2s ease-in-out;
    will-change: scale;
    padding: 4px;
    border-radius: var(--radius);
    background-image: linear-gradient(
      90deg,
      var(--gradientFrom),
      var(--gradientTo)
    );
  }

  .card__title {
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--grey-900);
    text-decoration: none;
  }
  .card:hover {
    scale: 0.98;
  }

  .card__inner {
    background-color: var(--background);
    padding: 1.5rem;
    border-radius: 0 0 var(--radius) var(--radius);
    display: flex;
    flex-direction: column;
  }
  .card__image {
    width: 100%;
    display: block;
  }

  .card__footer {
    margin: auto 0 0 auto;
    padding-top: 2rem;
    font-size: 1.2rem;
    color: var(--grey-900);
  }
</style>
