---
import Card from "./Card.astro";

import type { Props as CardProp } from "./Card.astro";

type Props = {
  cards: CardProp[];
};

const { cards } = Astro.props;
---

<div class="cards">
  {cards.map((card) => <Card {...card} />)}
</div>
<style>
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    /* background: salmon; */
  }
</style>
