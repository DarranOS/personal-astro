  <style>
    footer {
      padding-top: 2vh;
      padding-inline: var(--gutter);

    }
    
    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      width: 100%;
    }
        
    .footer-bottom {
      display: flex;
      justify-content: space-between;
    }


    .contact-link {  
      & a {
        display: flex;
        gap: 10px;
        align-items: center;

        & span {
          font-weight: 700;
          color: #Ffd944;
        }

        & svg {
          width: 24px;
          height: 24px;
          fill: #ffffff;
        }
      }
    }

    form {
    width: 100%;

    input,
    textarea {
      margin: 0.5vh 0;
      width: 100%;
      font-family: inherit;
      font-size: 1.1rem;
  
      padding: 0.8rem 1rem;
      /* background: rbga(255, 255, 255, 0.5); */
      display: block;
      resize: vertical;

      :focus {
        ${'' /* box-shadow: 0 1rem 2rem rgba(234, 160, 2, 0.6); */}
        border-bottom: 3px solid ${colors.compBlue};

        :invalid {
          border-bottom: 3px solid red;
        }
      }
      ::placeholder {
        color: ${colors.grey9};
      }
    }
  }

  form > input[type='submit'] {
    color: white;
    cursor: pointer;
    transition: all 0.2s;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 1rem;
    border: 3px solid transparent;
    border-radius: 0;

    :disabled {
      background: lightgrey;
    }

    :disabled:hover {
      background: lightgrey;
      transform: translateY(0);
      color: white;
      border: 3px solid lightgrey;
      cursor: not-allowed;
    }

    :hover {
      transform: translateY(-1rem);
      color: ${colors.compBlue};
      background: white;
      border: 3px solid ${colors.compBlue};
    }
    :active {
      transform: translateY(1rem);
      box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.6);
    }
  }
`
